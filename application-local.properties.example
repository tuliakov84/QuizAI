OTP_MAIL_HOST=smtp.yandex.ru
OTP_MAIL_PORT=465
OTP_MAIL_USERNAME=
OTP_MAIL_PASSWORD=
OTP_MAIL_AUTH=true
OTP_MAIL_STARTTLS=false
OTP_MAIL_SSL=true
OTP_MAIL_FROM=${OTP_MAIL_USERNAME}
OTP_MAIL_FROM_NAME=QuizAI

# Optional for local checks only
OTP_TEST_ENDPOINT_ENABLED=true

# Optional LLM overrides for local generation
APP_LLM_URL=http://localhost:11434/api/chat
APP_LLM_MODEL=qwen2.5
APP_LLM_CONNECT_TIMEOUT_SECONDS=30
APP_LLM_REQUEST_TIMEOUT_SECONDS=120
APP_LLM_MAX_RETRIES_PER_QUESTION=3
APP_LLM_TEMPERATURE=0.5
APP_LLM_NUM_PREDICT=1024

