# Standalone env for python-validation-worker repo/container
QUIZAI_DB_URL=jdbc:postgresql://postgres:5432/quizai
QUIZAI_DB_HOST=postgres
QUIZAI_DB_PORT=5432
QUIZAI_DB_NAME=quizai
QUIZAI_DB_USER=postgres
QUIZAI_DB_PASSWORD=postgres

QUIZAI_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
QUIZAI_KAFKA_AUTO_OFFSET_RESET=earliest
QUIZAI_PYTHON_VALIDATION_REQUESTS_TOPIC=python-validation-requests
QUIZAI_PYTHON_VALIDATION_RESULTS_TOPIC=python-validation-results

HF_HOME=/root/.cache/huggingface
TRANSFORMERS_CACHE=/root/.cache/huggingface

